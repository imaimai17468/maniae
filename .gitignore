# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (legacy — keep until all clones are clean)
.next/

# tanstack start (vite)
.output/
.tanstack/
.vite/
src/routeTree.gen.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# typescript
*.tsbuildinfo

*storybook.log
storybook-static
.superpowers/

# aegis (runtime DB is local-only; aegis-share/ is version-controlled)
.aegis/

# claude code runtime artifacts
.claude/scheduled_tasks.lock
.claude/.review-stamp
