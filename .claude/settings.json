{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__aegis__*",
      "mcp__aegis-admin__*",
      "mcp__plugin_context7_context7__*",
      "mcp__pencil__*",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__*",
      "mcp__claude_ai_Asana__*",
      "mcp__claude_ai_Atlassian__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_Slack__*",
      "WebSearch",
      "WebFetch",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh api:*)",
      "Bash(gh run view:*)",
      "Bash(bun run:*)",
      "Bash(bun add -E:*)",
      "Bash(bun remove:*)",
      "Bash(bun pm:*)",
      "Bash(bun install:*)",
      "Bash(bunx:*)",
      "Bash(wrangler types:*)",
      "Bash(wrangler d1 list:*)",
      "Bash(wrangler tail:*)",
      "Bash(drizzle-kit generate:*)",
      "Bash(ffmpeg:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout .)",
      "Bash(git checkout --:*)",
      "Bash(git restore .)",
      "Bash(git restore --:*)",
      "Bash(git commit --amend:*)",
      "Bash(git rebase -i:*)",
      "Bash(sudo:*)",
      "Bash(chmod -R:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.development)",
      "Write(./.env.production)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.development)",
      "Edit(./.env.production)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git revert:*)",
      "Bash(git tag:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue:*)",
      "Bash(bun add:*)",
      "Bash(bun run deploy:*)",
      "Bash(bun run preview:*)",
      "Bash(bun run db:push:*)",
      "Bash(bun run db:generate:*)",
      "Bash(wrangler deploy:*)",
      "Bash(wrangler d1 execute:*)",
      "Bash(wrangler r2:*)",
      "Bash(wrangler secret:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["aegis", "aegis-admin"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start-aegis-hydrate.sh",
            "timeout": 120,
            "statusMessage": "Aegis hydrate: building local knowledge base from aegis-share/source if missing..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-skill-reminder.sh",
            "timeout": 5,
            "statusMessage": "Skill reminder: confirm brainstorming / writing-plans / aegis_compile_context as needed..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-quality-gate.sh",
            "timeout": 120,
            "statusMessage": "Quality gate: typecheck / lint / format + knip / similarity (all blocking)..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-aegis-sync-check.sh",
            "timeout": 10,
            "statusMessage": "Aegis sync check: verifying knowledge base is up to date with rule/ADR changes..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__aegis__aegis_compile_context|mcp__aegis-admin__aegis_compile_context",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-aegis-intent-tags-guard.sh",
            "timeout": 5,
            "statusMessage": "Pre-aegis intent_tags guard: confirming intent_tags is specified..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-aegis-clear-review-stamp.sh",
            "timeout": 3,
            "statusMessage": "Clearing review stamp for new implementation cycle..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-agent-aegis-guard.sh",
            "timeout": 5,
            "statusMessage": "Pre-agent guard: confirming aegis_compile_context invocation..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-review-reminder.sh",
            "timeout": 5,
            "statusMessage": "Review reminder: checking code-reviewer dispatch..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "F=$(jq -r '.tool_input.file_path // \"\"'); case \"$F\" in *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs) ;; *) exit 0 ;; esac; cd $CLAUDE_PROJECT_DIR && OUT=$(bun run lint 2>&1 && bun run typecheck 2>&1); RC=$?; if [ $RC -ne 0 ]; then printf '%s' \"$OUT\" | jq -Rs --arg file \"$F\" '{systemMessage:(\"⛔ PostToolUse block: lint/typecheck 失敗 — \" + $file), decision:\"block\", reason:(\"PostToolUse: 編集後の lint / typecheck が失敗しました。次のツール呼び出し前に直してください。\\n\\n\" + .)}'; fi; exit 0",
            "timeout": 60,
            "statusMessage": "Per-edit check: lint + typecheck..."
          }
        ]
      },
      {
        "matcher": "mcp__aegis__aegis_compile_context|mcp__aegis-admin__aegis_compile_context",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-aegis-near-miss-warn.sh",
            "timeout": 3,
            "statusMessage": "Post-aegis near-miss warn: glob_no_match edge_hint を確認..."
          }
        ]
      },
      {
        "matcher": "mcp__aegis-admin__aegis_sync_docs|mcp__aegis-admin__aegis_import_doc",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-aegis-share-sync.sh",
            "timeout": 120,
            "statusMessage": "Aegis share sync: DB -> aegis-share/ (format -> lint -> materialize -> export)..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-agent-review-stamp.sh",
            "timeout": 3,
            "statusMessage": "Review stamp: checking if code-reviewer completed..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "plansDirectory": "./.claude/plans"
}
